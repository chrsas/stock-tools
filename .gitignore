### VS Code
# Ignore VS Code config by default; share only project task/launch/extension
# files. settings.json stays local; it tends to hold personal editor prefs
# (fonts, themes), not team configuration.
.vscode/*
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Local History for Visual Studio Code
.history/

# Built Visual Studio Code Extensions
*.vsix
